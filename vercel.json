{
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/", "dest": "/company.html" },
    { "src": "/app/suite/(.*)", "dest": "/index.html" },
    { "src": "/app/suite", "dest": "/index.html" },
    { "src": "/app/(.*)", "dest": "/index.html" },
    { "src": "/app", "dest": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  }
}
